{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@mvp/core": ["packages/core/src/index.ts"],
      "@mvp/adapters": ["packages/adapters/src/index.ts"],
      "@mvp/storage": ["packages/storage/src/index.ts"],
      "@mvp/api": ["packages/api/src/index.ts"],
      "@whetiq/auth": ["packages/auth/src/index.ts"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  }
}
