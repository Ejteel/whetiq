{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "baseUrl": "../../",
    "paths": {
      "@mvp/core": [
        "packages/core/src/index.ts"
      ],
      "@mvp/adapters": [
        "packages/adapters/src/index.ts"
      ],
      "@mvp/storage": [
        "packages/storage/src/index.ts"
      ],
      "@mvp/api": [
        "packages/api/src/index.ts"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "isolatedModules": true
  },
  "references": [
    {
      "path": "../../packages/core"
    },
    {
      "path": "../../packages/api"
    }
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
