# Copy to .env.local (web) or export in your shell before running.
# Never commit real keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Set to true for a safe public demo that never calls provider APIs.
DEMO_MODE=false
# Only used when DEMO_MODE=true on hosted deployments.
# When true, allows PRIVATE_AUTH_MODE=none behavior for public demo access.
PUBLIC_DEMO=false

# Private auth mode:
# - none: no auth
# - basic: shared HTTP Basic Auth
# - hybrid: HTTP Basic Auth + OAuth
# - oauth: GitHub OAuth via NextAuth (supports provider-side 2FA)
# If unset on Vercel preview/production, middleware defaults to oauth
# (or none only for PUBLIC_DEMO=true + DEMO_MODE=true).
PRIVATE_AUTH_MODE=none

# Basic mode credentials
PRIVATE_AUTH_USERNAME=
PRIVATE_AUTH_PASSWORD=

# OAuth mode (GitHub and/or Google)
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional private-pilot allowlist for oauth mode:
# Comma-separated list of exact emails and/or domains.
# If both are empty, any authenticated oauth user is allowed.
ALLOWED_EMAILS=
ALLOWED_DOMAINS=

# Optional runtime control-plane integration for apps/web:
# - demo: force demo mode
# - private_live: force real provider calls
APP_RUNTIME_MODE=
CONTROL_PLANE_SETTINGS_URL=
CONTROL_PLANE_APP_ID=aggregator-web
CONTROL_PLANE_SERVICE_TOKEN=
