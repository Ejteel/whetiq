{
  "name": "canonical-chat-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "setup": "npm install && npm run doctor",
    "doctor": "node scripts/doctor.mjs",
    "dev": "npm run build && concurrently -k \"npm:dev:web\" \"npm:dev:desktop\"",
    "dev:web": "npm run -w @mvp/web dev",
    "dev:admin": "npm run -w @mvp/admin dev",
    "dev:desktop": "npm run -w @mvp/desktop dev",
    "build:web": "npm run -w @mvp/web build",
    "build:admin": "npm run -w @mvp/admin build",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:local": "WEB_BASE_URL=http://127.0.0.1:3001 ADMIN_BASE_URL=http://127.0.0.1:3010 npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "lint": "echo 'lint not yet configured'"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1"
  }
}
