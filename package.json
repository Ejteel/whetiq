{
  "name": "canonical-chat-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "setup": "npm install && npm run doctor",
    "doctor": "node scripts/doctor.mjs",
    "dev": "npm run build && concurrently -k \"npm:dev:web\" \"npm:dev:desktop\"",
    "dev:web": "npm run -w @mvp/web dev",
    "dev:desktop": "npm run -w @mvp/desktop dev",
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.1",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.30.1",
    "wait-on": "^8.0.1"
  }
}
